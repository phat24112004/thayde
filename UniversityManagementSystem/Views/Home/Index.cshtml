@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        // Các biểu đồ cũ của bạn giữ nguyên
        @if (ViewBag.ChartLabels != null && ViewBag.ChartData != null)
        {
                <text>
                new Chart(document.getElementById('studentStatusChart').getContext('2d'), {
                    type: 'doughnut',
                    data: {
                        labels: @Html.Raw(ViewBag.ChartLabels),
                        datasets: [{
                            data: @Html.Raw(ViewBag.ChartData),
                            backgroundColor: ['#1a73e8', '#f2994a', '#28a745', '#dc3545', '#6c757d'],
                            borderWidth: 3, borderColor: '#ffffff'
                        }]
                    },
                    options: { responsive: true, maintainAspectRatio: false, cutout: '70%', plugins: { legend: { position: 'bottom' } } }
                });
                </text>
        }

        @if (ViewBag.GradeLabels != null && ViewBag.GradeData != null)
        {
                <text>
                new Chart(document.getElementById('gradeDistributionChart').getContext('2d'), {
                    type: 'bar',
                    data: {
                        labels: @Html.Raw(ViewBag.GradeLabels),
                        datasets: [{
                            label: 'Số lượng đạt được',
                            data: @Html.Raw(ViewBag.GradeData),
                            backgroundColor: ['rgba(40,167,69,0.8)', 'rgba(26,115,232,0.8)', 'rgba(255,193,7,0.8)', 'rgba(108,117,125,0.8)', 'rgba(220,53,69,0.8)'],
                            borderRadius: 6
                        }]
                    },
                    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } } }
                });
                </text>
        }

        // BỔ SUNG: Script vẽ biểu đồ Sinh viên theo Khoa
        @if (ViewBag.FacultyLabels != null && ViewBag.FacultyData != null)
        {
                <text>
                new Chart(document.getElementById('facultyStudentChart').getContext('2d'), {
                    type: 'bar',
                    data: {
                        labels: @Html.Raw(ViewBag.FacultyLabels),
                        datasets: [{
                            label: 'Sinh viên',
                            data: @Html.Raw(ViewBag.FacultyData),
                            backgroundColor: 'rgba(26, 115, 232, 0.7)',
                            borderColor: '#1a73e8',
                            borderWidth: 1,
                            borderRadius: 8,
                            barPercentage: 0.4
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { display: false } },
                        scales: {
                            y: { beginAtZero: true, ticks: { stepSize: 1 } },
                            x: { grid: { display: false } }
                        }
                    }
                });
                </text>
        }
    </script>
}