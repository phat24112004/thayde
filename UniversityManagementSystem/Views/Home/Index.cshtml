@* @{
    ViewData["Title"] = "Trang chủ - UniManager";
}

<style>
    /* CSS cho Slider Ảnh */
    .carousel-item {
        height: 450px;
        border-radius: 20px;
        overflow: hidden;
    }

        .carousel-item img {
            object-fit: cover;
            width: 100%;
            height: 100%;
        }

    .carousel-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.7));
    }

    .carousel-caption {
        bottom: 20%;
        z-index: 10;
        text-align: left;
        left: 8%;
        right: 8%;
    }

    /* CSS cho Card Thống kê */
    .stat-card {
        background: #ffffff;
        border-radius: 16px;
        border: none;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.04);
        transition: transform 0.3s ease;
    }

        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(26, 115, 232, 0.15);
        }

    .icon-box {
        width: 65px;
        height: 65px;
        border-radius: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
    }
</style>

<div class="container-fluid pt-2 pb-5">

    <div id="heroCarousel" class="carousel slide mb-5 shadow-lg" data-bs-ride="carousel" style="border-radius: 20px;">
        <div class="carousel-indicators">
            <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="0" class="active"></button>
            <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="1"></button>
            <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="2"></button>
        </div>

        <div class="carousel-inner" style="border-radius: 20px;">
            <div class="carousel-item active" data-bs-interval="4000">
                <img src="https://images.unsplash.com/photo-1541339907198-e08756dedf3f?q=80&w=1200&auto=format&fit=crop" alt="University">
                <div class="carousel-overlay"></div>
                <div class="carousel-caption">
                    <span class="badge bg-warning text-dark mb-2 px-3 py-2 fs-6 rounded-pill">Chuyển đổi số</span>
                    <h1 class="display-4 fw-bold text-white mb-3">Hệ thống Quản lý Đại học</h1>
                    <p class="fs-5 text-light opacity-75 d-none d-md-block w-75">Nền tảng số hóa toàn diện giúp kết nối Giảng viên, Sinh viên và Ban giám hiệu một cách nhanh chóng, minh bạch và hiệu quả.</p>
                </div>
            </div>

            <div class="carousel-item" data-bs-interval="4000">
                <img src="https://images.unsplash.com/photo-1523050854058-8df90110c9f1?q=80&w=1200&auto=format&fit=crop" alt="Students">
                <div class="carousel-overlay"></div>
                <div class="carousel-caption">
                    <h1 class="display-4 fw-bold text-white mb-3">Quản lý Sinh viên Thông minh</h1>
                    <p class="fs-5 text-light opacity-75 d-none d-md-block w-75">Theo dõi hồ sơ, quá trình học tập và trạng thái của hàng ngàn sinh viên chỉ bằng vài cú click chuột.</p>
                    <a asp-controller="Students" asp-action="Index" class="btn btn-primary px-4 py-2 mt-2 fw-bold rounded-pill">Truy cập Hồ sơ</a>
                </div>
            </div>

            <div class="carousel-item" data-bs-interval="4000">
                <img src="https://images.unsplash.com/photo-1519389950473-47ba0277781c?q=80&w=1200&auto=format&fit=crop" alt="Technology">
                <div class="carousel-overlay"></div>
                <div class="carousel-caption">
                    <h1 class="display-4 fw-bold text-white mb-3">Thống kê Điểm số Trực quan</h1>
                    <p class="fs-5 text-light opacity-75 d-none d-md-block w-75">Hệ thống tính toán tự động, xét chuẩn đầu ra và cung cấp biểu đồ phổ điểm chi tiết cho từng môn học.</p>
                </div>
            </div>
        </div>

        <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
        </button>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-sm-6 col-lg-3">
            <div class="stat-card p-4 h-100 d-flex align-items-center">
                <div class="icon-box bg-info bg-opacity-10 text-info me-3"><i class="fa-solid fa-sitemap"></i></div>
                <div>
                    <p class="text-muted mb-1 fw-semibold">Khoa / Tổ bộ môn</p>
                    <h3 class="fw-bold mb-0">@ViewBag.TotalFaculties</h3>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="stat-card p-4 h-100 d-flex align-items-center">
                <div class="icon-box bg-success bg-opacity-10 text-success me-3"><i class="fa-solid fa-chalkboard-user"></i></div>
                <div>
                    <p class="text-muted mb-1 fw-semibold">Lớp học hành chính</p>
                    <h3 class="fw-bold mb-0">@ViewBag.TotalClasses</h3>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="stat-card p-4 h-100 d-flex align-items-center">
                <div class="icon-box bg-warning bg-opacity-10 text-warning me-3"><i class="fa-solid fa-user-graduate"></i></div>
                <div>
                    <p class="text-muted mb-1 fw-semibold">Tổng số Sinh viên</p>
                    <h3 class="fw-bold mb-0">@ViewBag.TotalStudents</h3>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="stat-card p-4 h-100 d-flex align-items-center">
                <div class="icon-box bg-danger bg-opacity-10 text-danger me-3"><i class="fa-solid fa-book-open"></i></div>
                <div>
                    <p class="text-muted mb-1 fw-semibold">Môn học đào tạo</p>
                    <h3 class="fw-bold mb-0">@ViewBag.TotalSubjects</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-lg-6">
            <div class="card stat-card h-100">
                <div class="card-header bg-transparent border-0 pt-4 pb-0">
                    <h5 class="fw-bold text-primary mb-0"><i class="fa-solid fa-chart-pie me-2"></i>Thống kê Trạng thái Sinh viên</h5>
                </div>
                <div class="card-body d-flex justify-content-center align-items-center" style="position: relative; height:320px;">
                    <canvas id="studentStatusChart"></canvas>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card stat-card h-100">
                <div class="card-header bg-transparent border-0 pt-4 pb-0">
                    <h5 class="fw-bold text-primary mb-0"><i class="fa-solid fa-chart-column me-2"></i>Phổ điểm Chuẩn Đầu ra</h5>
                </div>
                <div class="card-body d-flex justify-content-center align-items-center" style="position: relative; height:320px;">
                    <canvas id="gradeDistributionChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        // KIỂM TRA & VẼ BIỂU ĐỒ TRÒN
        @if (ViewBag.ChartLabels != null && ViewBag.ChartData != null)
        {
                <text>
                const labels = @Html.Raw(ViewBag.ChartLabels);
                const data = @Html.Raw(ViewBag.ChartData);

                new Chart(document.getElementById('studentStatusChart').getContext('2d'), {
                    type: 'doughnut',
                    data: {
                        labels: labels,
                        datasets: [{
                            data: data,
                            backgroundColor: ['#1a73e8', '#f2994a', '#28a745', '#dc3545', '#6c757d'],
                            borderWidth: 3, borderColor: '#ffffff'
                        }]
                    },
                    options: { responsive: true, maintainAspectRatio: false, cutout: '70%', plugins: { legend: { position: 'bottom' } } }
                });
                </text>
        }

        // KIỂM TRA & VẼ BIỂU ĐỒ CỘT
        @if (ViewBag.GradeLabels != null && ViewBag.GradeData != null)
        {
                <text>
                const gradeLabels = @Html.Raw(ViewBag.GradeLabels);
                const gradeData = @Html.Raw(ViewBag.GradeData);

                new Chart(document.getElementById('gradeDistributionChart').getContext('2d'), {
                    type: 'bar',
                    data: {
                        labels: gradeLabels,
                        datasets: [{
                            label: 'Số lượng đạt được',
                            data: gradeData,
                            backgroundColor: ['rgba(40,167,69,0.8)', 'rgba(26,115,232,0.8)', 'rgba(255,193,7,0.8)', 'rgba(108,117,125,0.8)', 'rgba(220,53,69,0.8)'],
                            borderRadius: 6
                        }]
                    },
                    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } } }
                });
                </text>
        }
    </script>
} *@
