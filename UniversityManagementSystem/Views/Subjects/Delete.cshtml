@model UniversityManagementSystem.Models.Subject

@{
    ViewData["Title"] = "Xóa Môn học";
}

<div class="container pt-5 pb-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">

            <div class="mb-4">
                <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-danger bg-opacity-10 text-danger" style="width: 90px; height: 90px;">
                    <i class="fa-solid fa-book-skull fa-3x"></i>
                </div>
            </div>

            <h2 class="fw-bolder mb-3">Xóa môn học này?</h2>
            <p class="text-muted fs-5 mb-4">
                Hành động này <strong class="text-danger">không thể hoàn tác</strong>. Môn học
                <strong class="text-dark">@Model.SubjectName</strong> sẽ bị xóa khỏi hệ thống. (Lưu ý: Không thể xóa nếu đã có sinh viên có điểm môn này).
            </p>

            <div class="card shadow-lg border-danger border-opacity-50 text-start">
                <div class="card-body p-4 bg-light rounded">
                    <form asp-action="Delete">
                        <input type="hidden" asp-for="SubjectId" />

                        <div class="mb-4">
                            <label class="form-label text-muted">
                                Vui lòng nhập mã môn <span class="user-select-all text-danger fw-bold bg-danger bg-opacity-10 px-2 py-1 rounded border border-danger border-opacity-25">@Model.SubjectId</span> để xác nhận:
                            </label>
                            <input type="text" id="confirmInputSubject" class="form-control form-control-lg border-danger border-opacity-50" autocomplete="off" placeholder="Nhập mã môn học..." />
                        </div>

                        <div class="d-grid gap-3">
                            <button type="submit" id="btnDeleteSubject" class="btn btn-danger btn-lg fw-bold shadow-sm" disabled>
                                <i class="fa-solid fa-trash-can me-2"></i> Xác nhận Xóa Môn học
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg">
                                Hủy và Quay lại
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const confirmInput = document.getElementById('confirmInputSubject');
        const btnDelete = document.getElementById('btnDeleteSubject');
        const targetId = "@Html.Raw(Model.SubjectId)";

        confirmInput.addEventListener('input', function() {
            if (this.value.trim() === targetId.trim()) {
                btnDelete.removeAttribute('disabled');
            } else {
                btnDelete.setAttribute('disabled', 'true');
            }
        });
    </script>
}