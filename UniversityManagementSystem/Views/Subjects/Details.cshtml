                            </li>
                        </ul>
                    </div>

                    <div class="d-flex justify-content-end mt-5 pt-4 border-top">
                        <a asp-action="Edit" asp-route-id="@Model?.SubjectId" class="btn text-dark px-5 py-2 fw-bold shadow-sm" style="background-color: #ffc107; border-radius: 10px; font-size: 1.05rem;">
