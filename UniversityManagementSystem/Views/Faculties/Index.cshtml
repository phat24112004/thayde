@* @model IEnumerable<UniversityManagementSystem.Models.Faculty>

@{
    ViewData["Title"] = "Khối / Tổ bộ môn";
}

<style>
    /* CSS dùng chung cho bảng dữ liệu (giống trang Học sinh) */
    .table-custom {
        border-collapse: separate;
        border-spacing: 0 10px;
        background-color: transparent;
    }

        .table-custom thead th {
            border: none;
            color: #6c757d;
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.85rem;
            letter-spacing: 0.5px;
        }

        .table-custom tbody tr {
            background-color: #ffffff;
            box-shadow: 0 2px 8px rgba(0,0,0,0.04);
            border-radius: 10px;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

            .table-custom tbody tr:hover {
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(0,0,0,0.08);
            }

        .table-custom tbody td {
            border: none;
            vertical-align: middle;
            padding: 15px 10px;
        }

            .table-custom tbody td:first-child {
                border-top-left-radius: 10px;
                border-bottom-left-radius: 10px;
            }

            .table-custom tbody td:last-child {
                border-top-right-radius: 10px;
                border-bottom-right-radius: 10px;
            }

    .pagination .page-link {
        border: none;
        color: #555;
        border-radius: 8px;
        margin: 0 4px;
        font-weight: 500;
    }

    .pagination .page-item.active .page-link {
        background-color: #1a73e8;
        color: white;
        box-shadow: 0 3px 8px rgba(26, 115, 232, 0.4);
    }
</style>

<div class="container-fluid pt-2">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="text-primary mb-1 fw-bold"><i class="fa-solid fa-sitemap me-2"></i>Khối / Tổ bộ môn</h3>
            <p class="text-muted mb-0" style="font-size: 0.9rem;">Quản lý danh sách các khối lớp và tổ bộ môn trong trường</p>
        </div>

        <a asp-action="Create" class="btn btn-primary shadow-sm px-4 d-flex align-items-center py-2" style="border-radius: 8px; font-weight: 600;">
            <i class="fa-solid fa-plus me-2"></i> Thêm mới
        </a>
    </div>

    <div class="card border-0 shadow-sm mb-4" style="border-radius: 12px;">
        <div class="card-body p-3">
            <form asp-action="Index" method="get" class="m-0 d-flex justify-content-end align-items-center">
                <div class="input-group bg-light p-1" style="width: 350px; border-radius: 10px;">
                    <span class="input-group-text bg-transparent border-0 text-muted ps-3">
                        <i class="fa-solid fa-magnifying-glass"></i>
                    </span>
                    <input type="text" name="searchString" value="@ViewData["CurrentFilter"]"
                           class="form-control border-0 bg-transparent shadow-none"
                           placeholder="Nhập tên tổ hoặc khối..." autocomplete="off">

                    @if (!string.IsNullOrEmpty(ViewData["CurrentFilter"]?.ToString()))
                    {
                        <a asp-action="Index" class="btn btn-sm text-danger border-0 d-flex align-items-center" title="Hủy tìm kiếm">
                            <i class="fa-solid fa-xmark fs-5"></i>
                        </a>
                    }
                    <button type="submit" class="btn text-white px-4 fw-bold shadow-sm" style="background-color: #f2994a; border-radius: 8px;">Tìm</button>
                </div>
            </form>
        </div>
    </div>

    <div class="table-responsive px-1">
        <table class="table table-custom text-center align-middle w-100">
            <thead>
                <tr>
                    <th class="ps-3 text-start" style="width: 20%;">Mã Tổ / Khối</th>
                    <th class="text-start">Tên Tổ / Khối</th>
                    <th class="pe-3" style="width: 20%;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-3 text-start fw-bold" style="color: #555;">
                            <span class="badge" style="background-color: #e8f0fe; color: #1a73e8; padding: 6px 12px; border-radius: 6px;">
                                @Html.DisplayFor(modelItem => item.FacultyId)
                            </span>
                        </td>
                        <td class="text-start fw-bold" style="color: #333; font-size: 1.05rem;">
                            <i class="fa-solid fa-layer-group text-warning me-2" style="opacity: 0.7;"></i>
                            @Html.DisplayFor(modelItem => item.FacultyName)
                        </td>
                        <td class="pe-3">
                            <div class="d-flex justify-content-center gap-2">
                                <a asp-action="Details" asp-route-id="@item.FacultyId" class="btn btn-sm btn-light text-info rounded-circle shadow-sm" style="width: 32px; height: 32px; padding: 5px;" title="Chi tiết">
                                    <i class="fa-solid fa-circle-info"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@item.FacultyId" class="btn btn-sm btn-light text-warning rounded-circle shadow-sm" style="width: 32px; height: 32px; padding: 5px;" title="Sửa">
                                    <i class="fa-solid fa-pen"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.FacultyId" class="btn btn-sm btn-light text-danger rounded-circle shadow-sm" style="width: 32px; height: 32px; padding: 5px;" title="Xóa">
                                    <i class="fa-solid fa-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (ViewBag.TotalPages > 1)
    {
        <nav class="mt-2 mb-5">
            <ul class="pagination justify-content-center shadow-sm d-inline-flex p-2 bg-white" style="border-radius: 12px;">
                <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-pageNumber="@(ViewBag.CurrentPage - 1)" asp-route-searchString="@ViewData["CurrentFilter"]">
                        <i class="fa-solid fa-chevron-left"></i>
                    </a>
                </li>
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-pageNumber="@i" asp-route-searchString="@ViewData["CurrentFilter"]">@i</a>
                    </li>
                }
                <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-pageNumber="@(ViewBag.CurrentPage + 1)" asp-route-searchString="@ViewData["CurrentFilter"]">
                        <i class="fa-solid fa-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    }
</div> *@
@model IEnumerable<UniversityManagementSystem.Models.Faculty>

@{
    ViewData["Title"] = "Quản lý Khoa Đào tạo";
}

<style>
    /* CSS đồng bộ giao diện bảng Neumorphism */
    .table-custom {
        border-collapse: separate;
        border-spacing: 0 10px;
        background-color: transparent;
    }

        .table-custom thead th {
            border: none;
            color: #6c757d;
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.85rem;
            letter-spacing: 0.5px;
        }

        .table-custom tbody tr {
            background-color: #ffffff;
            box-shadow: 0 2px 8px rgba(0,0,0,0.04);
            border-radius: 10px;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

            .table-custom tbody tr:hover {
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(0,0,0,0.08);
            }

        .table-custom tbody td {
            border: none;
            vertical-align: middle;
            padding: 15px 10px;
        }

            .table-custom tbody td:first-child {
                border-top-left-radius: 10px;
