</style>

<div class="container-fluid pt-2 pb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="text-primary mb-1 fw-bold"><i class="fa-solid fa-sitemap me-2"></i>Khoa Đào tạo</h3>
            <p class="text-muted mb-0" style="font-size: 0.9rem;">Quản lý cơ cấu tổ chức các khoa và bộ môn trong trường</p>
        </div>

        <a asp-action="Create" class="btn btn-primary shadow-sm px-4 d-flex align-items-center py-2" style="border-radius: 8px; font-weight: 600;">
            <i class="fa-solid fa-plus me-2"></i> Thêm Khoa mới
        </a>
    </div>

    <div class="card border-0 shadow-sm mb-4" style="border-radius: 12px;">
        <div class="card-body p-3 d-flex justify-content-end">
            <form asp-action="Index" method="get" class="m-0">
                <div class="input-group bg-light p-1" style="width: 350px; border-radius: 10px;">
                    <span class="input-group-text bg-transparent border-0 text-muted ps-3">
                        <i class="fa-solid fa-magnifying-glass"></i>
                    </span>
                    <input type="text" name="searchString" value="@ViewData["CurrentFilter"]"
                           class="form-control border-0 bg-transparent shadow-none"
                           placeholder="Nhập tên Khoa cần tìm..." autocomplete="off">

                    @if (!string.IsNullOrEmpty(ViewData["CurrentFilter"]?.ToString()))
                    {
                        <a asp-action="Index" class="btn btn-sm text-danger border-0 d-flex align-items-center" title="Hủy tìm kiếm">
                            <i class="fa-solid fa-xmark fs-5"></i>
                        </a>
                    }
                    <button type="submit" class="btn text-white px-4 fw-bold shadow-sm" style="background-color: #f2994a; border-radius: 8px;">Tìm</button>
                </div>
            </form>
        </div>
    </div>

    <div class="table-responsive px-1">
        <table class="table table-custom align-middle w-100">
            <thead>
                <tr>
                    <th class="ps-3 text-start" style="width: 15%;">Mã Khoa</th>
                    <th class="text-start" style="width: 65%;">Tên Khoa Đào tạo</th>
                    <th class="pe-3 text-center" style="width: 20%;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-3 text-start fw-bold" style="color: #555;">
                            @Html.DisplayFor(modelItem => item.FacultyId)
                        </td>

                        <td class="text-start fw-bold text-primary" style="font-size: 1.05rem;">
                            <div class="d-flex align-items-center" style="transform: translateX(-5px);">
                                <div class="bg-light text-info rounded-circle d-flex align-items-center justify-content-center me-3 shadow-sm" style="width: 32px; height: 32px; font-size: 0.85rem;">
                                    <i class="fa-solid fa-building-columns"></i>
                                </div>
                                <span style="transform: translateY(1px);">@Html.DisplayFor(modelItem => item.FacultyName)</span>
                            </div>
                        </td>

                        <td class="pe-3">
                            <div class="d-flex justify-content-center gap-2">
                                <a asp-action="Details" asp-route-id="@item.FacultyId" class="btn btn-sm btn-light text-info rounded-circle shadow-sm" style="width: 32px; height: 32px; padding: 5px;" title="Chi tiết">
                                    <i class="fa-solid fa-circle-info"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@item.FacultyId" class="btn btn-sm btn-light text-warning rounded-circle shadow-sm" style="width: 32px; height: 32px; padding: 5px;" title="Sửa">
                                    <i class="fa-solid fa-pen"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.FacultyId" class="btn btn-sm btn-light text-danger rounded-circle shadow-sm" style="width: 32px; height: 32px; padding: 5px;" title="Xóa">
