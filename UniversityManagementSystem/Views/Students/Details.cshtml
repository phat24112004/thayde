@* @model UniversityManagementSystem.Models.Student

@{
    ViewData["Title"] = "Hồ sơ Sinh viên";
}

<div class="container-fluid pt-4 pb-5">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">

            <div class="d-flex align-items-center mb-4">
                <a asp-action="Index" class="btn btn-light shadow-sm text-secondary rounded-circle me-3" style="width: 40px; height: 40px; padding: 8px;">
                    <i class="fa-solid fa-arrow-left"></i>
                </a>
                <h3 class="text-primary mb-0 fw-bold">Chi tiết Hồ sơ</h3>
            </div>

            <div class="card shadow-sm border-0" style="border-radius: 15px; overflow: hidden;">
                <div class="bg-primary bg-gradient" style="height: 120px;"></div>

                <div class="card-body px-4 px-md-5 pb-5 pt-0">
                    <div class="d-flex flex-column flex-sm-row align-items-sm-end mb-5" style="margin-top: -50px;">

                        <div class="bg-white rounded-circle p-2 shadow" style="width: 110px; height: 110px; display: inline-block;">
                            <div class="w-100 h-100 rounded-circle d-flex align-items-center justify-content-center" style="background: linear-gradient(135deg, #e8f0fe 0%, #d2e3fc 100%); font-size: 2.5rem; color: #1a73e8;">
                                @if (Model.Gender == "Nữ")
                                {
                                    <i class="fa-solid fa-person-dress text-danger opacity-75"></i>
                                }
                                else
                                {
                                    <i class="fa-solid fa-user-graduate"></i>
                                }
                            </div>
                        </div>

                        <div class="ms-sm-4 mt-3 mt-sm-0 mb-2">
                            <h3 class="fw-bold text-dark mb-1">@Model.FullName</h3>
                            <span class="badge bg-light text-primary border border-primary border-opacity-25 px-3 py-2 fs-6">
                                <i class="fa-solid fa-id-card me-1"></i> @Model.StudentId
                            </span>
                        </div>

                        <div class="ms-sm-auto mt-3 mt-sm-0 mb-2">
                            @switch (Model.Status)
                            {
                                case "Đang học":
                                    <span class="badge bg-success px-4 py-2 rounded-pill shadow-sm fs-6"><i class="fa-solid fa-check-circle me-1"></i> Đang học</span>
                                    break;
                                case "Bảo lưu":

                                    <span class="badge bg-warning text-dark px-4 py-2 rounded-pill shadow-sm fs-6"><i class="fa-solid fa-pause-circle me-1"></i> Bảo lưu</span>
                                    break;
                                case "Đã tốt nghiệp":

                                    <span class="badge bg-primary px-4 py-2 rounded-pill shadow-sm fs-6"><i class="fa-solid fa-graduation-cap me-1"></i> Tốt nghiệp</span>
                                    break;
                                case "Đuổi học":
                                case "Thôi học":

                                    <span class="badge bg-danger px-4 py-2 rounded-pill shadow-sm fs-6"><i class="fa-solid fa-ban me-1"></i> Thôi học</span>
                                    break;
                                default:

                                    <span class="badge bg-secondary px-4 py-2 rounded-pill shadow-sm fs-6">@(string.IsNullOrEmpty(Model.Status) ? "Chưa rõ" : Model.Status)</span>
                                    break;
                            }
                        </div>
                    </div>

                    <div class="row g-4">

                        <div class="col-md-6">
                            <h6 class="text-primary fw-bold text-uppercase mb-3" style="letter-spacing: 0.5px;"><i class="fa-solid fa-address-card me-2"></i>Thông tin cá nhân</h6>
                            <div class="bg-light p-4 rounded-3 border border-primary border-opacity-10 h-100">
                                <ul class="list-unstyled mb-0">
                                    <li class="mb-4 d-flex align-items-center">
                                        <div class="bg-white rounded d-flex align-items-center justify-content-center shadow-sm me-3" style="width: 40px; height: 40px;"><i class="fa-solid fa-venus-mars text-info fs-5"></i></div>
                                        <div>
                                            <small class="text-muted d-block fw-semibold" style="font-size: 0.85rem;">Giới tính</small>
                                            <span class="fw-bold text-dark" style="font-size: 1.05rem;">@(string.IsNullOrEmpty(Model.Gender) ? "Chưa cập nhật" : Model.Gender)</span>
                                        </div>
                                    </li>
                                    <li class="mb-4 d-flex align-items-center">
                                        <div class="bg-white rounded d-flex align-items-center justify-content-center shadow-sm me-3" style="width: 40px; height: 40px;"><i class="fa-regular fa-calendar-days text-primary fs-5"></i></div>
                                        <div>
                                            <small class="text-muted d-block fw-semibold" style="font-size: 0.85rem;">Ngày sinh</small>
                                            <span class="fw-bold text-dark" style="font-size: 1.05rem;">@(Model.DateOfBirth?.ToString("dd/MM/yyyy") ?? "Chưa cập nhật")</span>
                                        </div>
                                    </li>
                                    <li class="d-flex align-items-center">
                                        <div class="bg-white rounded d-flex align-items-center justify-content-center shadow-sm me-3" style="width: 40px; height: 40px;"><i class="fa-solid fa-chalkboard-user text-success fs-5"></i></div>
                                        <div>
                                            <small class="text-muted d-block fw-semibold" style="font-size: 0.85rem;">Lớp học</small>
                                            <span class="fw-bold text-success" style="font-size: 1.05rem;">@(Model.SchoolClass?.ClassName ?? "Chưa phân lớp")</span>
                                        </div>
                                    </li>
                                </ul>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <h6 class="text-primary fw-bold text-uppercase mb-3" style="letter-spacing: 0.5px;"><i class="fa-solid fa-address-book me-2"></i>Thông tin liên lạc</h6>
                            <div class="bg-light p-4 rounded-3 border border-primary border-opacity-10 h-100">
                                <ul class="list-unstyled mb-0">
                                    <li class="mb-4 d-flex align-items-center">
                                        <div class="bg-white rounded d-flex align-items-center justify-content-center shadow-sm me-3" style="width: 40px; height: 40px;"><i class="fa-solid fa-envelope text-warning fs-5"></i></div>
                                        <div>
                                            <small class="text-muted d-block fw-semibold" style="font-size: 0.85rem;">Email</small>
                                            <span class="fw-bold text-dark" style="font-size: 1.05rem;">@(string.IsNullOrEmpty(Model.Email) ? "Chưa cập nhật" : Model.Email)</span>
                                        </div>
                                    </li>
                                    <li class="mb-4 d-flex align-items-center">
                                        <div class="bg-white rounded d-flex align-items-center justify-content-center shadow-sm me-3" style="width: 40px; height: 40px;"><i class="fa-solid fa-phone text-success fs-5"></i></div>
                                        <div>
                                            <small class="text-muted d-block fw-semibold" style="font-size: 0.85rem;">Số điện thoại</small>
                                            <span class="fw-bold text-dark" style="font-size: 1.05rem;">@(string.IsNullOrEmpty(Model.PhoneNumber) ? "Chưa cập nhật" : Model.PhoneNumber)</span>
                                        </div>
                                    </li>
                                    <li class="d-flex align-items-center">
                                        <div class="bg-white rounded d-flex align-items-center justify-content-center shadow-sm me-3" style="width: 40px; height: 40px;"><i class="fa-solid fa-location-dot text-danger fs-5"></i></div>
                                        <div>
                                            <small class="text-muted d-block fw-semibold" style="font-size: 0.85rem;">Địa chỉ</small>
                                            <span class="fw-bold text-dark" style="font-size: 1.05rem;">@(string.IsNullOrEmpty(Model.Address) ? "Chưa cập nhật" : Model.Address)</span>
                                        </div>
                                    </li>
                                </ul>
                            </div>
                        </div>

                    </div>

                    <div class="d-flex justify-content-end mt-5 pt-4 border-top">
                        <a asp-action="Edit" asp-route-id="@Model?.StudentId" class="btn text-dark px-5 py-2 fw-bold shadow-sm" style="background-color: #ffc107; border-radius: 10px; font-size: 1.05rem;">
                            <i class="fa-solid fa-pen-to-square me-2"></i> CẬP NHẬT HỒ SƠ
                        </a>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div> *@
