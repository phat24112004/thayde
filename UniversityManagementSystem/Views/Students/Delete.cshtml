@model UniversityManagementSystem.Models.Student

@{
    ViewData["Title"] = "Xóa Sinh viên";
}

<div class="container pt-5 pb-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">

            <div class="mb-4">
                <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-danger bg-opacity-10 text-danger" style="width: 90px; height: 90px;">
                    <i class="fa-solid fa-user-xmark fa-3x"></i>
                </div>
            </div>

            <h2 class="fw-bolder mb-3">Xóa hồ sơ sinh viên?</h2>
            <p class="text-muted fs-5 mb-4">
                Hành động này <strong class="text-danger">không thể hoàn tác</strong>. Mọi dữ liệu (bao gồm cả điểm số) của sinh viên
                <strong class="text-dark fs-4">@Model.FullName</strong> (@Model.StudentId) sẽ bị xóa vĩnh viễn.
            </p>

            <div class="card shadow-lg border-danger border-opacity-50 text-start">
                <div class="card-body p-4 bg-light rounded">
                    <form asp-action="Delete">
                        <input type="hidden" asp-for="StudentId" />

                        <div class="mb-4">
                            <label class="form-label text-muted">Vui lòng nhập họ tên <span class="user-select-all text-danger fw-bold bg-danger bg-opacity-10 px-2 py-1 rounded border border-danger border-opacity-25">@Model.FullName</span> để xác nhận:</label>
                            <input type="text" id="confirmInputStudent" class="form-control form-control-lg border-danger border-opacity-50" autocomplete="off" placeholder="Nhập họ và tên..." />
                        </div>

                        <div class="d-grid gap-3">
                            <button type="submit" id="btnDeleteStudent" class="btn btn-danger btn-lg fw-bold shadow-sm" disabled>
                                <i class="fa-solid fa-trash-can me-2"></i> Xác nhận Xóa Sinh viên
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg">
                                Hủy và Quay lại
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const confirmInput = document.getElementById('confirmInputStudent');
        const btnDelete = document.getElementById('btnDeleteStudent');
        const targetName = "@Html.Raw(Model.FullName)";

        confirmInput.addEventListener('input', function() {
            if (this.value.trim() === targetName.trim()) {
                btnDelete.removeAttribute('disabled');
            } else {
                btnDelete.setAttribute('disabled', 'true');
            }
        });
    </script>
}