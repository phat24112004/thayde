<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - UniversityManagementSystem</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="https://bootswatch.com/5/pulse/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/UniversityManagementSystem.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                    <i class="fa-solid fa-graduation-cap me-2"></i>UniManager
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                <i class="fa-solid fa-house me-1"></i> Trang chủ
                            </a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown" href="#" role="button" aria-haspopup="true" aria-expanded="false">
                                <i class="fa-solid fa-list-check me-1"></i> Danh mục Quản lý
                            </a>
                            <div class="dropdown-menu shadow">
                                <a class="dropdown-item" asp-controller="Faculties" asp-action="Index">
                                    <i class="fa-solid fa-school me-2 text-info"></i>Quản lý Khoa
                                </a>
                                <a class="dropdown-item" asp-controller="SchoolClasses" asp-action="Index">
                                    <i class="fa-solid fa-chalkboard-user me-2 text-success"></i>Quản lý Lớp học
                                </a>
                                <div class="dropdown-divider"></div>
                                <a class="dropdown-item" asp-controller="Students" asp-action="Index">
                                    <i class="fa-solid fa-user-graduate me-2 text-warning"></i>Quản lý Sinh viên
                                </a>
                                <a class="dropdown-item" asp-controller="Grades" asp-action="Index">
                                    <i class="fa-solid fa-star me-2 text-danger"></i>Quản lý Điểm
                                </a>
                                <a class="dropdown-item" asp-controller="Subjects" asp-action="Index">
                                    <i class="fa-solid fa-book me-2 text-secondary"></i>Quản lý Môn học
                                </a>
                            </div>
                        </li>
                    </ul>

                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link" href="#"><i class="fa-solid fa-user me-1"></i> Admin</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - UniversityManagementSystem - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // Kiểm tra xem Controller có gửi thông báo Thành công không
        @if (TempData["SuccessMessage"] != null)
        {
                <text>
                Swal.fire({
                    icon: 'success',
                    title: 'Thành công!',
                    text: '@Html.Raw(TempData["SuccessMessage"])',
                    showConfirmButton: false,
                    timer: 2000 // Tự động đóng sau 2 giây
                });
                </text>
        }

        // Kiểm tra xem Controller có gửi thông báo Lỗi không
        @if (TempData["ErrorMessage"] != null)
        {
                <text>
                Swal.fire({
                    icon: 'error',
                    title: 'Ối, có lỗi rồi!',
                    text: '@Html.Raw(TempData["ErrorMessage"])'
                });
                </text>
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>