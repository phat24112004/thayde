    .pagination .page-item.active .page-link {
        background-color: #1a73e8;
        color: white;
        box-shadow: 0 3px 8px rgba(26, 115, 232, 0.4);
    }
</style>

<div class="container-fluid pt-2 pb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="text-primary mb-1 fw-bold"><i class="fa-solid fa-star-half-stroke me-2"></i>Bảng Điểm Sinh Viên</h3>
            <p class="text-muted mb-0" style="font-size: 0.9rem;">Tra cứu, cập nhật và xuất báo cáo kết quả học tập</p>
        </div>
        <div class="d-flex align-items-center gap-2">
            @if (User.IsInRole("Admin"))
                {
                    <button type="button" class="btn btn-success shadow-sm px-3 d-flex align-items-center py-2" style="border-radius: 8px; font-weight: 600;" data-bs-toggle="modal" data-bs-target="#importGradeModal">
                        <i class="fa-solid fa-file-import me-2"></i> Nhập Excel
                    </button>
                    <a asp-action="ExportToExcel" class="btn btn-light shadow-sm text-primary px-3 d-flex align-items-center py-2" style="border-radius: 8px; font-weight: 600;">
                        <i class="fa-solid fa-file-excel me-2"></i> Xuất Excel
                    </a>
                    <a asp-action="Create" class="btn btn-primary shadow-sm px-4 d-flex align-items-center py-2" style="border-radius: 8px; font-weight: 600;">
                        <i class="fa-solid fa-plus me-2"></i> Nhập điểm mới
                    </a>
                }
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4" style="border-radius: 12px;">
        <div class="card-body p-3">
            <form asp-action="Index" method="get" class="m-0 d-flex flex-wrap gap-3 align-items-center">
                <div class="d-flex align-items-center gap-2">
                    <i class="fa-solid fa-book text-muted"></i>
                    <select name="subjectId" class="form-select border-0 bg-light" style="width: 200px; border-radius: 8px;" asp-items="ViewBag.SubjectList" onchange="this.form.submit()">
                        <option value="">-- Tất cả Môn học --</option>
                    </select>
                </div>
                <div class="flex-grow-1"></div>
                <div class="input-group bg-light p-1" style="width: 350px; border-radius: 10px;">
                    <span class="input-group-text bg-transparent border-0 text-muted ps-3"><i class="fa-solid fa-magnifying-glass"></i></span>
                    <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control border-0 bg-transparent shadow-none" placeholder="Nhập tên sinh viên..." autocomplete="off">
                    @if (!string.IsNullOrEmpty(ViewData["CurrentFilter"]?.ToString()) || !string.IsNullOrEmpty(ViewData["CurrentSubjectId"]?.ToString()))
                    {
                        <a asp-action="Index" class="btn btn-sm text-danger border-0 d-flex align-items-center" title="Hủy tìm kiếm"><i class="fa-solid fa-xmark fs-5"></i></a>
                    }
                    <button type="submit" class="btn text-white px-4 fw-bold shadow-sm" style="background-color: #f2994a; border-radius: 8px;">Tìm</button>
                </div>
            </form>
        </div>
    </div>

    <div class="table-responsive px-1">
        <table class="table table-custom text-center align-middle w-100">
            <thead>
                <tr>
                    <th class="ps-3 text-start">Sinh viên</th>
                    <th>Môn học</th>
                    <th>Tổng kết (Hệ 10)</th>
                    <th>Điểm Chữ</th>
                    <th>Học kỳ</th>
                    <th class="pe-3">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-3 text-start fw-bold" style="color: #333;">
                            <div class="d-flex align-items-center">
                                <div class="avatar-sm shadow-sm"><i class="fa-solid fa-user-graduate"></i></div>
                                <span>@Html.DisplayFor(modelItem => item.Student.FullName)</span>
                            </div>
                        </td>
                        <td class="fw-bold text-secondary">@Html.DisplayFor(modelItem => item.Subject.SubjectName)</td>
                        <td><span class="fw-bold" style="font-size: 1.1rem; color: #555;">@(item.TotalScore?.ToString("0.00") ?? "-")</span></td>
                        <td>
                            @switch (item.LetterGrade)
                            {
                                case "A":
                                    <span class="badge bg-success px-3 py-2 fs-6 rounded-pill shadow-sm">A</span>
                                    break;
                                case "B":

                                    <span class="badge bg-primary px-3 py-2 fs-6 rounded-pill shadow-sm">B</span>
                                    break;
                                case "C":

                                    <span class="badge bg-warning text-dark px-3 py-2 fs-6 rounded-pill shadow-sm">C</span>
                                    break;
                                case "D":

                                    <span class="badge bg-secondary px-3 py-2 fs-6 rounded-pill shadow-sm">D</span>
                                    break;
                                case "F":

                                    <span class="badge bg-danger px-3 py-2 fs-6 rounded-pill shadow-sm" style="animation: pulse 2s infinite;">F</span>
                                    break;
                                default:

                                    <span class="badge bg-light text-muted border px-3 py-2 fs-6 rounded-pill">-</span>
                                    break;
                            }
                        </td>
                        <td><span class="badge bg-light text-dark border px-2 py-1">@Html.DisplayFor(modelItem => item.Semester)</span></td>
                        <td class="pe-3">
                            <div class="d-flex justify-content-center gap-2">
                                <a asp-action="Details" asp-route-id="@item.GradeId" class="btn btn-sm btn-light text-info rounded-circle shadow-sm" style="width: 32px; height: 32px; padding: 5px;" title="Chi tiết"><i class="fa-solid fa-circle-info"></i></a>
                                @if (User.IsInRole("Admin"))
                                    {
                                        <a asp-action="Edit" asp-route-id="@item.GradeId" class="btn btn-sm btn-light text-warning rounded-circle shadow-sm" style="width: 32px; height: 32px; padding: 5px;" title="Sửa"><i class="fa-solid fa-pen"></i></a>
                                        <a asp-action="Delete" asp-route-id="@item.GradeId" class="btn btn-sm btn-light text-danger rounded-circle shadow-sm" style="width: 32px; height: 32px; padding: 5px;" title="Xóa"><i class="fa-solid fa-trash"></i></a>
                                    }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (ViewBag.TotalPages > 1)
    {
        <nav class="mt-2">
            <ul class="pagination justify-content-center shadow-sm d-inline-flex p-2 bg-white" style="border-radius: 12px;">
                <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-pageNumber="@(ViewBag.CurrentPage - 1)" asp-route-searchString="@ViewData["CurrentFilter"]" asp-route-subjectId="@ViewData["CurrentSubjectId"]"><i class="fa-solid fa-chevron-left"></i></a>
                </li>
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-pageNumber="@i" asp-route-searchString="@ViewData["CurrentFilter"]" asp-route-subjectId="@ViewData["CurrentSubjectId"]">@i</a>
                    </li>
                }
                <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-pageNumber="@(ViewBag.CurrentPage + 1)" asp-route-searchString="@ViewData["CurrentFilter"]" asp-route-subjectId="@ViewData["CurrentSubjectId"]"><i class="fa-solid fa-chevron-right"></i></a>
                </li>
            </ul>
        </nav>
    }

    <div class="modal fade" id="importGradeModal" tabindex="-1" aria-labelledby="importGradeModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow" style="border-radius: 15px;">

                <div class="modal-header bg-success text-white" style="border-top-left-radius: 15px; border-top-right-radius: 15px;">
                    <h5 class="modal-title fw-bold" id="importGradeModalLabel"><i class="fa-solid fa-file-import me-2"></i>Nhập Bảng điểm từ Excel</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <form asp-action="ImportExcel" method="post" enctype="multipart/form-data">
                    <div class="modal-body p-4">

                        <div class="alert alert-success border-0 bg-success bg-opacity-10 d-flex align-items-center mb-4" style="border-radius: 10px;">
                            <div class="me-3 text-success">
                                <i class="fa-solid fa-circle-down fa-2x"></i>
                            </div>
                            <div>
                                <h6 class="fw-bold mb-1 text-success">Bước 1: Tải File Mẫu</h6>
                                <p class="mb-2" style="font-size: 0.9rem;">Tải file mẫu về, nhập điểm theo đúng định dạng. Hệ thống sẽ tự động tính Điểm tổng kết và Điểm chữ.</p>
                                <a asp-action="DownloadTemplate" class="btn btn-sm btn-success fw-bold rounded-pill px-3 shadow-sm">
                                    <i class="fa-solid fa-download me-1"></i> Tải Template_NhapDiem.xlsx
                                </a>
                            </div>
                        </div>

                        <div>
                            <h6 class="fw-bold text-dark mb-2"><i class="fa-solid fa-cloud-arrow-up text-primary me-2"></i>Bước 2: Chọn file tải lên <span class="text-danger">*</span></h6>
                            <input type="file" name="file" id="file" class="form-control form-control-lg bg-light border-0 shadow-sm" accept=".xlsx, .xls" required style="border-radius: 10px;" />
                            <small class="text-muted mt-2 d-block"><i class="fa-solid fa-triangle-exclamation text-warning me-1"></i>Sẽ bỏ qua nếu SV đang bị đình chỉ, bảo lưu hoặc nhập sai mã.</small>
                        </div>

                    </div>

                    <div class="modal-footer bg-light border-0" style="border-bottom-left-radius: 15px; border-bottom-right-radius: 15px;">
                        <button type="button" class="btn btn-secondary px-4 fw-bold shadow-sm" data-bs-dismiss="modal" style="border-radius: 8px;">Hủy</button>
                        <button type="submit" class="btn btn-primary px-4 fw-bold shadow-sm" style="border-radius: 8px;">
                            <i class="fa-solid fa-check-circle me-1"></i> Bắt đầu Nhập điểm
                        </button>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>