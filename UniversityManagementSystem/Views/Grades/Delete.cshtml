@model UniversityManagementSystem.Models.Grade

@{
    ViewData["Title"] = "Xóa điểm số";
}

<div class="container-fluid d-flex justify-content-center align-items-center" style="min-height: 75vh;">

    <div class="card border-0 shadow-lg" style="max-width: 450px; width: 100%; border-radius: 20px; overflow: hidden;">

        <div class="bg-danger bg-gradient text-white text-center py-4">
            <div class="bg-white text-danger rounded-circle d-inline-flex align-items-center justify-content-center mb-2 shadow" style="width: 70px; height: 70px;">
                <i class="fa-solid fa-trash-can fa-2x"></i>
            </div>
            <h4 class="mb-0 fw-bold">Xác nhận xóa điểm?</h4>
        </div>

        <div class="card-body p-4 text-center">
            <p class="text-muted mb-4" style="font-size: 0.95rem;">
                Hành động này <strong>không thể hoàn tác</strong>. Bản ghi điểm số này sẽ bị xóa vĩnh viễn khỏi hệ thống.
            </p>

            <div class="bg-light rounded-3 p-3 mb-4 text-start border border-danger border-opacity-25" style="box-shadow: inset 0 2px 4px rgba(0,0,0,0.02);">
                <div class="d-flex align-items-center mb-2">
                    <i class="fa-solid fa-user-graduate text-secondary me-2" style="width: 20px;"></i>
                    <span class="text-muted me-2">Học sinh:</span>
                    <strong class="text-dark">@Model.Student?.FullName</strong>
                </div>
                <div class="d-flex align-items-center mb-2">
                    <i class="fa-solid fa-book text-secondary me-2" style="width: 20px;"></i>
                    <span class="text-muted me-2">Môn học:</span>
                    <strong class="text-dark">@Model.Subject?.SubjectName</strong>
                </div>
                <div class="d-flex align-items-center mb-2">
                    <i class="fa-solid fa-star-half-stroke text-secondary me-2" style="width: 20px;"></i>
                    <span class="text-muted me-2">Điểm số:</span>
                    <strong class="text-danger fs-5">@Model.TotalScore</strong>
                </div>
                <div class="d-flex align-items-center">
                    <i class="fa-regular fa-calendar text-secondary me-2" style="width: 20px;"></i>
                    <span class="text-muted me-2">Học kỳ:</span>
                    <strong class="text-dark">@Model.Semester</strong>
                </div>
            </div>

            <form asp-action="Delete">
                <input type="hidden" asp-for="GradeId" />

                <div class="d-flex justify-content-center gap-3">
                    <a asp-action="Index" class="btn btn-light border shadow-sm px-4 py-2 fw-bold" style="border-radius: 10px; color: #555;">
                        Quay lại
                    </a>
                    <button type="submit" class="btn btn-danger shadow-sm px-4 py-2 fw-bold" style="border-radius: 10px;">
                        <i class="fa-solid fa-trash me-1"></i> Xóa
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>