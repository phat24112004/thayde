@model UniversityManagementSystem.Models.Grade

@{
    ViewData["Title"] = "Chi tiết Điểm";
}

<div class="container pt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow border-0">
                <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
                    <h4 class="mb-0"><i class="fa-solid fa-star-half-stroke me-2"></i>Kết quả Học tập</h4>

                    @if (Model.Score >= 5)
                    {
                        <span class="badge bg-success fs-6"><i class="fa-solid fa-check me-1"></i> Qua môn</span>
                    }
                    else
                    {
                        <span class="badge bg-danger fs-6"><i class="fa-solid fa-xmark me-1"></i> Học lại</span>
                    }
                </div>
                <div class="card-body p-4">
                    <div class="text-center mb-4">
                        <h1 class="display-1 fw-bolder @(Model.Score >= 5 ? "text-success" : "text-danger")">
                            @Html.DisplayFor(model => model.Score)
                        </h1>
                        <p class="text-muted">Điểm tổng kết</p>
                    </div>

                    <dl class="row fs-5 bg-light p-3 rounded">
                        <dt class="col-sm-4 text-muted">Mã SV</dt>
                        <dd class="col-sm-8 fw-bold">@Html.DisplayFor(model => model.StudentId)</dd>

                        <dt class="col-sm-4 text-muted">Họ và Tên</dt>
                        <dd class="col-sm-8 fw-bold text-primary">@Html.DisplayFor(model => model.Student.FullName)</dd>

                        <dt class="col-sm-4 text-muted">Môn học</dt>
                        <dd class="col-sm-8 fw-bold text-info">@Html.DisplayFor(model => model.Subject.SubjectName)</dd>
                    </dl>
                </div>
                <div class="card-footer bg-light text-end p-3">
                    <a asp-action="Index" class="btn btn-secondary me-2">
                        <i class="fa-solid fa-arrow-left"></i> Quay lại danh sách
                    </a>
                    <a asp-action="Edit" asp-route-id="@Model?.GradeId" class="btn btn-warning fw-bold">
                        <i class="fa-solid fa-pen-to-square"></i> Cập nhật điểm
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>